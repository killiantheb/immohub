# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Althy
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/althy

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
# IDs des prix Stripe Billing (créer dans le dashboard Stripe)
STRIPE_PRICE_PROPRIO_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
STRIPE_PRICE_PORTAL_MONTHLY=price_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAILS_FROM=noreply@althy.ch

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+41...

# ── Transit Airbnb — QR-factures loyers ──────────────────────────────────────
# QR-IBAN du compte courant Althy (format CH + 19 chiffres, obtenu depuis PostFinance)
ALTHY_QR_IBAN=CH0000000000000000000
# Commission Althy sur loyers en transit (3% par défaut)
ALTHY_COMMISSION_PCT=0.03
# Nom de la banque Althy pour l'en-tête des QR-factures
ALTHY_BANK_NAME=PostFinance
# Coordonnées créancier affichées sur la QR-facture
ALTHY_CREDITOR_NAME=Althy SA
ALTHY_CREDITOR_STREET=Rue de Rive 1
ALTHY_CREDITOR_CITY=1204 Genève
ALTHY_CREDITOR_COUNTRY=CH

# ── WhatsApp Business API (Meta) ─────────────────────────────────────────────
WHATSAPP_API_TOKEN=                     # Token d'accès permanent (System User)
WHATSAPP_PHONE_ID=                      # Phone Number ID (depuis Meta Business)
WHATSAPP_VERIFY_TOKEN=althy-wh-verify-change-me  # Token de vérification webhook (string random)
META_APP_SECRET=                        # App Secret (depuis Meta Developer Console → Settings → Basic)

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
